#!/bin/bash
echo "current module: $BKPAAS_APP_MODULE_NAME"

if [ "$BKPAAS_APP_MODULE_NAME" == "default" ]; then
    echo "source code deploy, current module is 'default', run post_compile"
    python manage.py migrate --no-input
else
    echo "smart pack deploy, current module is not 'default', skip post_compile"
fi